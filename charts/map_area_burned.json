{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Choropleth of area burned by state during Black Summer",
  "width": "container",
  "height": 300,
  "projection": {
    "type": "mercator"
  },
  "data": {
    "url": "data/STE_2016_AUST.json",
    "format": {
      "type": "topojson",
      "feature": "STE_2016_AUST"
    }
  },
  "transform": [
    {
      "lookup": "properties.STE_NAME16",
      "from": {
        "data": {
          "url": "data/australia_bushfire_impact.csv"
        },
        "key": "state",
        "fields": [
          "area_ha",
          "fatalities",
          "homes_lost"
        ]
      }
    }
  ],
  "mark": {
    "type": "geoshape",
    "stroke": "#fff",
    "strokeWidth": 0.8
  },
  "encoding": {
    "color": {
      "field": "area_ha",
      "type": "quantitative",
      "scale": {
        "type": "sqrt",
        "range": [
          "#FEF0D9",
          "#FC8D59",
          "#D7301F",
          "#7F0000"
        ]
      },
      "legend": {
        "title": "Area burned (ha)",
        "values": [
          50000,
          500000,
          2000000,
          5000000
        ],
        "format": "~s"
      }
    },
    "tooltip": [
      {
        "field": "properties.STE_NAME16",
        "type": "nominal",
        "title": "State"
      },
      {
        "field": "area_ha",
        "type": "quantitative",
        "title": "Area burned (ha)",
        "format": ","
      },
      {
        "field": "homes_lost",
        "type": "quantitative",
        "title": "Homes lost",
        "format": ","
      },
      {
        "field": "fatalities",
        "type": "quantitative",
        "title": "Fatalities"
      }
    ]
  },
  "config": {
    "font": "Inter, sans-serif",
    "axis":   { "labelFont": "Inter, sans-serif", "titleFont": "Inter, sans-serif", "labelColor": "#65605a", "titleColor": "#3a3530" },
    "legend": { "labelFont": "Inter, sans-serif", "titleFont": "Inter, sans-serif" },
    "header": { "labelFont": "Inter, sans-serif" },
    "view":   { "stroke": null }
  },
  "autosize": {
    "type": "fit",
    "contains": "padding"
  }
}