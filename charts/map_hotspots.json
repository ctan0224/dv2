{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Random sample of raw fire hotspot points across Australia",
  "width": "container",
  "height": 500,
  "projection": {
    "type": "mercator"
  },
  "layer": [
    {
      "data": {
        "url": "data/STE_2016_AUST.json",
        "format": {
          "type": "topojson",
          "feature": "STE_2016_AUST"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#f5f0e8",
        "stroke": "#ccc",
        "strokeWidth": 0.8
      }
    },
    {
      "data": {
        "url": "data/fire_sample.csv"
      },
      "mark": {
        "type": "circle",
        "size": 8,
        "opacity": 0.6
      },
      "encoding": {
        "longitude": {
          "field": "longitude",
          "type": "quantitative"
        },
        "latitude": {
          "field": "latitude",
          "type": "quantitative"
        },
        "color": {
          "field": "frp",
          "type": "quantitative",
          "scale": {
            "type": "log",
            "domain": [
              5,
              1100
            ],
            "range": [
              "#FEF0D9",
              "#FC8D59",
              "#D7301F",
              "#7F0000"
            ]
          },
          "legend": {
            "title": "Fire intensity (MW)",
            "values": [
              5,
              20,
              50,
              150,
              500,
              1100
            ],
            "format": ".0f",
            "orient": "bottom-left"
          }
        },
        "tooltip": [
          {
            "field": "acq_date",
            "type": "temporal",
            "title": "Date",
            "format": "%d %b %Y"
          },
          {
            "field": "frp",
            "type": "quantitative",
            "title": "Fire intensity (MW)",
            "format": ".1f"
          },
          {
            "field": "brightness",
            "type": "quantitative",
            "title": "Brightness (K)",
            "format": ".1f"
          }
        ]
      }
    }
  ],
  "config": {
    "font": "Inter, sans-serif",
    "axis":   { "labelFont": "Inter, sans-serif", "titleFont": "Inter, sans-serif", "labelColor": "#65605a", "titleColor": "#3a3530" },
    "legend": { "labelFont": "Inter, sans-serif", "titleFont": "Inter, sans-serif" },
    "header": { "labelFont": "Inter, sans-serif" },
    "view":   { "stroke": null }
  },
  "autosize": {
    "type": "fit",
    "contains": "padding"
  }
}